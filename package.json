{
  "name": "sosync",
  "version": "1.0.0",
  "main": "./index.js",
  "scripts": {
    "start": "expo start",
    "start:clear": "expo start --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "doctor:android-live": "node ./scripts/checkAndroidLiveSetup.mjs",
    "qa:android-emulator": "node ./scripts/qaAndroidEmulator.mjs",
    "backfill:circle-codes": "npm --prefix functions run backfill:circle-data --",
    "seed:live-data": "npm --prefix functions run seed:test-data --",
    "seed:live-alert": "npm --prefix functions run seed:manual-alert --",
    "typecheck": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "firebase:emulators": "firebase emulators:start --only auth,firestore,functions",
    "firebase:deploy:functions": "firebase deploy --only functions",
    "firebase:deploy:firestore": "firebase deploy --only firestore:rules,firestore:indexes",
    "firebase:deploy:storage": "firebase deploy --only storage",
    "firebase:deploy:backend": "firebase deploy --only functions,firestore:rules,firestore:indexes,storage",
    "functions:build": "npm --prefix functions run build",
    "functions:serve": "npm --prefix functions run serve",
    "eas:build:android:preview": "eas build --platform android --profile preview",
    "eas:build:android:production": "eas build --platform android --profile production",
    "eas:submit:android:production": "eas submit --platform android --profile production"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@gorhom/bottom-sheet": "^5.2.8",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-native-firebase/app": "^23.8.8",
    "@react-native-firebase/auth": "^23.8.8",
    "@react-native-firebase/firestore": "^23.8.8",
    "@react-native-firebase/functions": "^23.8.8",
    "@react-native-firebase/messaging": "^23.8.8",
    "@react-native-firebase/storage": "^23.8.8",
    "axios": "^1.13.6",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "expo": "~55.0.6",
    "expo-build-properties": "~55.0.9",
    "expo-clipboard": "^55.0.9",
    "expo-constants": "~55.0.7",
    "expo-dev-client": "~55.0.16",
    "expo-device": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-image-picker": "^55.0.13",
    "expo-linking": "~55.0.7",
    "expo-location": "~55.1.2",
    "expo-notifications": "~55.0.12",
    "expo-router": "~55.0.5",
    "expo-splash-screen": "~55.0.10",
    "expo-status-bar": "~55.0.4",
    "expo-system-ui": "~55.0.9",
    "nativewind": "^4.2.3",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "~2.30.0",
    "react-native-maps": "1.26.20",
    "react-native-reanimated": "4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-web": "^0.21.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^3.4.19",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.0",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.11",
    "jest-expo": "^55.0.9",
    "react-test-renderer": "^19.2.0",
    "typescript": "~5.9.2"
  },
  "engines": {
    "node": "24.14.0"
  },
  "packageManager": "npm@11.8.0",
  "private": true
}
